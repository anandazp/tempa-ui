---
interface Tab {
  label: string;
}

interface Props {
  tabs: Tab[];
  activeIndex?: number;
  class?: string;
}

const {
  tabs,
  activeIndex = 0,
  class: className = "",
} = Astro.props;
---

<div class={`tabs ${className}`}>
  <div class="flex border-b border-black-onyx/10" role="tablist">
    {tabs.map((tab, i) => (
      <button
        class={`tab-btn px-4 py-2 text-sm text-black-onyx/60 hover:text-black-onyx transition-colors ${i === activeIndex ? "tab-btn-active text-black-onyx font-medium border-b-2 border-black-onyx" : ""}`}
        role="tab"
        aria-selected={i === activeIndex}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <div class="mt-4">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll(".tabs").forEach((tabs) => {
    const tabButtons = tabs.querySelectorAll(".tab-btn");
    const panels = tabs.querySelectorAll("[data-tab-panel]");

    function activateTab(index) {
      tabButtons.forEach((btn, i) => {
        const isActive = i === index;
        btn.classList.toggle("tab-btn-active", isActive);
        btn.classList.toggle("text-black-onyx", isActive);
        btn.classList.toggle("font-medium", isActive);
        btn.classList.toggle("border-b-2", isActive);
        btn.classList.toggle("border-black-onyx", isActive);
        btn.setAttribute("aria-selected", isActive);
      });
      panels.forEach((panel, i) => {
        panel.classList.toggle("active", i === index);
        panel.style.display = i === index ? "block" : "none";
      });
    }

    const activeBtn = tabs.querySelector(".tab-btn-active");
    const initialIndex = activeBtn ? Array.from(tabButtons).indexOf(activeBtn) : 0;
    activateTab(initialIndex);

    tabButtons.forEach((btn, i) => {
      btn.addEventListener("click", () => activateTab(i));
    });
  });
</script>
