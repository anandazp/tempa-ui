---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import { siteData } from "../data/site";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <Navbar />

    <main class="w-full px-6 py-10 bg-white-ghost">
      <slot />
    </main>

    <footer class="bg-black-onyx text-white-ghost mt-20">
      <div class="w-full px-6 py-16">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-10">
          <div class="md:col-span-1">
            <h6 class="text-lg font-semibold text-white-ghost! mb-3">
              {siteData.brand}
            </h6>
            <p class="text-sm text-white-ghost/80 leading-relaxed">
              Simple UI components built with Astro and Tailwind CSS. Copy,
              paste, build.
            </p>
          </div>
          <div>
            <h6
              class="text-sm font-semibold text-white-ghost/90 mb-4 uppercase tracking-wider"
            >
              Resources
            </h6>
            <ul class="space-y-2.5">
              <li>
                <a
                  href="/docs"
                  class="text-sm text-white-ghost/50 hover:text-white-ghost transition-colors"
                  >Documentation</a>
              </li>
              <li>
                <a
                  href="/docs/components"
                  class="text-sm text-white-ghost/50 hover:text-white-ghost transition-colors"
                  >Components</a>
              </li>
            </ul>
          </div>
          <div>
            <h6
              class="text-sm font-semibold text-white-ghost/70 mb-4 uppercase tracking-wider"
            >
              Connect
            </h6>
            <ul class="space-y-2.5">
              <li>
                <a
                  href="https://github.com"
                  class="text-sm text-white-ghost/50 hover:text-white-ghost transition-colors"
                  >GitHub</a>
              </li>
              <li>
                <a
                  href="https://anandazp.netlify.app"
                  class="text-sm text-white-ghost/50 hover:text-white-ghost transition-colors"
                  >Creator</a>
              </li>
            </ul>
          </div>
          <div>
            <h6
              class="text-sm font-semibold text-white-ghost/70 mb-4 uppercase tracking-wider"
            >
              Newsletter
            </h6>
            <p class="text-sm text-white-ghost/50 mb-4">
              Get updates on new components and tips.
            </p>
            <form class="flex gap-2">
              <input
                type="email"
                placeholder="your@email.com"
                class="flex-1 px-3 py-2 text-sm bg-white-ghost/10 border border-white-ghost/20 rounded text-white-ghost placeholder:text-white-ghost/30 outline-none focus:border-white-ghost/50 transition-colors"
              />
              <button
                type="submit"
                class="shrink-0 px-4 py-2 text-sm bg-white-ghost text-black-onyx rounded font-medium hover:bg-white-ghost/90 transition-colors cursor-pointer"
                >Subscribe</button
              >
            </form>
          </div>
        </div>
        <div
          class="max-w-6xl mx-auto mt-12 pt-8 border-t border-white-ghost/10 text-center"
        >
          <p class="text-sm text-white-ghost/30">
            &copy; {new Date().getFullYear()}
            {siteData.brand}. MIT Licensed.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
