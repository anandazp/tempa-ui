---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import { siteData } from "../data/site";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />

    <div class="flex">
      <aside
        class="fixed left-0 top-16 h-[calc(100vh-4rem)] hidden lg:flex flex-col bg-white-ghost border-r border-black-onyx/10 w-56 py-6 z-40"
      >
        <nav class="flex-1 overflow-y-auto px-4">
          <ul class="flex flex-col gap-1">
            {
              siteData.sideNavigationDocs.map((link) => (
                <li>
                  <a href={link.href} class="docs-sidebar-menu">
                    {link.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a href="/docs/components/button" class="docs-sidebar-link"
                >Button</a
              >
            </li>
            <li>
              <a href="/docs/components/sidebar" class="docs-sidebar-link"
                >Sidebar</a
              >
            </li>
            <li>
              <a href="/docs/components/tabs" class="docs-sidebar-link">Tabs</a>
            </li>
            <li>
              <a href="/docs/components/breadcrumbs" class="docs-sidebar-link"
                >Breadcrumbs</a
              >
            </li>
            <li>
              <a href="/docs/components/alert" class="docs-sidebar-link">Alert</a>
            </li>
            <li>
              <a href="/docs/components/card" class="docs-sidebar-link">Card</a>
            </li>
            <li>
              <a href="/docs/components/modal" class="docs-sidebar-link">Modal</a>
            </li>
          </ul>
        </nav>
      </aside>
      <main class="flex-1 lg:ml-56">
        <slot />
      </main>
    </div>

    <footer>
      <h6>{title}</h6>
    </footer>
  </body>
</html>
