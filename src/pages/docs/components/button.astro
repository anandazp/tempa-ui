---
import { siteData } from "../../../data/site";

import DocsLayout from "../../../layouts/DocsLayout.astro";
import MainButton from "../../../components/MainButton.astro";
import CodeBlock from "../../../components/CodeBlock.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import MainButtonSource from "../../../components/MainButton.astro?raw";

const usageCode = `<MainButton variant='primary'>Get Started</MainButton>
<MainButton variant='outline' href='https://github.com'>View on GitHub</MainButton>`;
---

<DocsLayout title=`Button | ${siteData.brand}`>
  <section>
    <div class="space-y-1">
      <Breadcrumbs
        items={[
          { label: "Docs", href: "/docs" },
          { label: "Components", href: "/components" },
          { label: "Button" },
        ]}
      />
      <h2 class="section-title">Button</h2>
      <p class="section-description">Button for cta, outline, and link.</p>
    </div>

    <h3 class="section-subtitle">Code</h3>
    <CodeBlock
      code={MainButtonSource}
      showLineNumbers={true}
      fileName="components/MainButton.astro"
    />

    <h3 class="section-subtitle">Preview</h3>
    <div class="flex flex-col gap-5">
      <div class="preview-wrapper">
        <h4 class="preview-heading">Primary Button</h4>
        <MainButton>Get Started</MainButton>
      </div>
      <div class="preview-wrapper">
        <h4 class="preview-heading">Outline Button</h4>
        <MainButton variant="outline" href="https://github.com"
          >View on GitHub</MainButton
        >
      </div>
    </div>

    <h3 class="section-subtitle">Usage</h3>
    <CodeBlock language="javascript" code={usageCode} showLineNumbers={true} />

    <h3 class="section-subtitle">Props</h3>
    <div class="overflow-x-auto">
      <table class="props-table">
        <thead>
          <tr class="tr-head">
            <th class="th-cell">Prop</th>
            <th class="th-cell">Type</th>
            <th class="th-cell">Default</th>
            <th class="th-desc">Description</th>
          </tr>
        </thead>
        <tbody class="text-black-onyx/80">
          <tr class="tr-body">
            <td class="td-cell prop-name">code</td>
            <td class="td-cell prop-type">string</td>
            <td class="td-cell">—</td>
            <td class="td-desc">Source code to display.</td>
          </tr>
          <tr class="tr-body">
            <td class="td-cell prop-name">language</td>
            <td class="td-cell prop-type">string</td>
            <td class="td-cell prop-type">"html"</td>
            <td class="td-desc">Language for syntax highlighting.</td>
          </tr>
          <tr class="tr-body">
            <td class="td-cell prop-name">showLineNumbers</td>
            <td class="td-cell prop-type">boolean</td>
            <td class="td-cell prop-type">false</td>
            <td class="td-desc">Toggle line numbers.</td>
          </tr>
          <tr class="tr-body">
            <td class="td-cell prop-name">fileName</td>
            <td class="td-cell prop-type">string</td>
            <td class="td-cell">—</td>
            <td class="td-desc">Optional filename header.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>
