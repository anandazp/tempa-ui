---
import { siteData } from "../../../data/site";

import DocsLayout from "../../../layouts/DocsLayout.astro";
import Accordion from "../../../components/Accordion.astro";
import CodeBlock from "../../../components/CodeBlock.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import AccordionSource from "../../../components/Accordion.astro?raw";

const usageCode = `<Accordion
  items={[
    { title: "Getting Started", content: "Install the package..." },
    { title: "Customization", content: "Override CSS variables..." },
    { title: "API Reference", content: "Full component API..." },
  ]}
/>`;
---

<DocsLayout title=`Accordion | ${siteData.brand}`>
  <section>
    <div class="space-y-1">
      <Breadcrumbs
        items={[
          { label: "Docs", href: "/docs" },
          { label: "Components", href: "/components" },
          { label: "Accordion" },
        ]}
      />
      <h2 class="section-title">Accordion</h2>
      <p class="section-description">
        Expandable content panels for FAQs and documentation.
      </p>
    </div>

    <h3 class="section-subtitle">Code</h3>
    <CodeBlock
      code={AccordionSource}
      showLineNumbers={true}
      fileName="components/Accordion.astro"
    />

    <h3 class="section-subtitle">Preview</h3>
    <div class="flex flex-col gap-5">
      <div class="preview-wrapper">
        <h4 class="preview-heading">Default Accordion</h4>
        <Accordion
          items={[
            { title: "Getting Started", content: "Install the package using npm, yarn, or pnpm. Then import the components you need into your project." },
            { title: "Customization", content: "Override CSS variables to match your brand. All components use CSS custom properties for colors, spacing, and typography." },
            { title: "API Reference", content: "Each component exposes a set of props for customization. Check the documentation page for each component to see the full API." },
          ]}
        />
      </div>
    </div>

    <h3 class="section-subtitle">Usage</h3>
    <CodeBlock language="javascript" code={usageCode} showLineNumbers={true} />

    <h3 class="section-subtitle">Props</h3>
    <div class="overflow-x-auto">
      <table class="props-table">
        <thead>
          <tr class="tr-head">
            <th class="th-cell">Prop</th>
            <th class="th-cell">Type</th>
            <th class="th-cell">Default</th>
            <th class="th-desc">Description</th>
          </tr>
        </thead>
        <tbody>
          <tr class="tr-body">
            <td class="td-cell prop-name">items</td>
            <td class="td-cell prop-type">AccordionItem[]</td>
            <td class="td-cell">—</td>
            <td class="td-desc">Array of objects with title and content strings.</td>
          </tr>
          <tr class="tr-body">
            <td class="td-cell prop-name">class</td>
            <td class="td-cell prop-type">string</td>
            <td class="td-cell">—</td>
            <td class="td-desc">Additional CSS classes.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>
