---
import { components } from "../../../data/components";
import DocsLayout from "../../../layouts/DocsLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
---

<DocsLayout title="Components | Tempa UI">
  <section>
    <div class="space-y-1">
      <Breadcrumbs
        items={[{ label: "Docs", href: "/docs" }, { label: "Components" }]}
      />
      <h2 class="section-title">Components</h2>
      <p class="section-description">Here you can find all the components that available. We are still working to adding more components.</p>
    </div>

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3 mt-6">
      {components.map((c) => (
        <a
          href={`/docs/components${c.href}`}
          class="bg-white-ghost rounded overflow-hidden block hover:underline hover:underline-offset-4 transition-colors"
        >
          {c.label}
        </a>
      ))}
    </div>
  </section>
</DocsLayout>
