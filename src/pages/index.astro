---
import Layout from "../layouts/Layout.astro";
import Button from "../components/MainButton.astro";
import { siteData } from "../data/site";
---

<Layout title={siteData.brand}>
  <section id="hero" class=" w-full md:text-center">
    <h1 class="text-4xl lg:text-5xl font-semibold">{siteData.tagline}</h1>
    <p class="lg:text-lg lg:w-1/2 lg:mx-auto">{siteData.description}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 mx-auto gap-5 w-full md:w-3/4 lg:w-1/2">
      <Button href="/docs/components" class="w-full">Browse Components</Button>
      <Button href="/docs" variant="outline" class="">View Docs</Button>
    </div>
    <div class="mx-auto flex gap-5 mt-3">
      <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="text-black-onyx w-10 h-10"><title>Astro</title><path d="M8.358 20.162c-1.186-1.07-1.532-3.316-1.038-4.944.856 1.026 2.043 1.352 3.272 1.535 1.897.283 3.76.177 5.522-.678.202-.098.388-.229.608-.36.166.473.209.95.151 1.437-.14 1.185-.738 2.1-1.688 2.794-.38.277-.782.525-1.175.787-1.205.804-1.531 1.747-1.078 3.119l.044.148a3.158 3.158 0 0 1-1.407-1.188 3.31 3.31 0 0 1-.544-1.815c-.004-.32-.004-.642-.048-.958-.106-.769-.472-1.113-1.161-1.133-.707-.02-1.267.411-1.415 1.09-.012.053-.028.104-.045.165h.002zm-5.961-4.445s3.24-1.575 6.49-1.575l2.451-7.565c.092-.366.36-.614.662-.614.302 0 .57.248.662.614l2.45 7.565c3.85 0 6.491 1.575 6.491 1.575L16.088.727C15.93.285 15.663 0 15.303 0H8.697c-.36 0-.615.285-.784.727l-5.516 14.99z"/></svg>
      <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="text-black-onyx w-10 h-10"><title>TypeScript</title><path d="M1.125 0C.502 0 0 .502 0 1.125v21.75C0 23.498.502 24 1.125 24h21.75c.623 0 1.125-.502 1.125-1.125V1.125C24 .502 23.498 0 22.875 0zm17.363 9.75c.612 0 1.154.037 1.627.111a6.38 6.38 0 0 1 1.306.34v2.458a3.95 3.95 0 0 0-.643-.361 5.093 5.093 0 0 0-.717-.26 5.453 5.453 0 0 0-1.426-.2c-.3 0-.573.028-.819.086a2.1 2.1 0 0 0-.623.242c-.17.104-.3.229-.393.374a.888.888 0 0 0-.14.49c0 .196.053.373.156.529.104.156.252.304.443.444s.423.276.696.41c.273.135.582.274.926.416.47.197.892.407 1.266.628.374.222.695.473.963.753.268.279.472.598.614.957.142.359.214.776.214 1.253 0 .657-.125 1.21-.373 1.656a3.033 3.033 0 0 1-1.012 1.085 4.38 4.38 0 0 1-1.487.596c-.566.12-1.163.18-1.79.18a9.916 9.916 0 0 1-1.84-.164 5.544 5.544 0 0 1-1.512-.493v-2.63a5.033 5.033 0 0 0 3.237 1.2c.333 0 .624-.03.872-.09.249-.06.456-.144.623-.25.166-.108.29-.234.373-.38a1.023 1.023 0 0 0-.074-1.089 2.12 2.12 0 0 0-.537-.5 5.597 5.597 0 0 0-.807-.444 27.72 27.72 0 0 0-1.007-.436c-.918-.383-1.602-.852-2.053-1.405-.45-.553-.676-1.222-.676-2.005 0-.614.123-1.141.369-1.582.246-.441.58-.804 1.004-1.089a4.494 4.494 0 0 1 1.47-.629 7.536 7.536 0 0 1 1.77-.201zm-15.113.188h9.563v2.166H9.506v9.646H6.789v-9.646H3.375z"/></svg>
      <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="text-black-onyx w-10 h-10"><title>Tailwind CSS</title><path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C10.337,13.382,8.976,12,6.001,12z"/></svg>
    </div>
  </section>

  <section id="why-us">
    <div class="max-w-2xl">
      <h2 class="text-2xl lg:hidden font-medium w-3/4 md:w-full">
        Stop overthinking, Start creating
      </h2>
      <h2 class="hidden lg:block text-2xl lg:text-4xl font-medium w-3/4 md:w-full">
        Stop overthinking
      </h2>
      <h2 class="hidden lg:block  text-2xl lg:text-4xl font-medium w-3/4 md:w-full">
        Start creating
      </h2>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <h3 class="feature-title">Ready to Use</h3>
        <p class="feature-desc">
          No npm install. No build step. Copy the code and paste it directly
          into your project. Works immediately, every time.
        </p>

        <button
          class="my-5 py-2 px-5 rounded tracking-tight font-medium bg-black-onyx text-white-ghost"
          >Copy</button
        >
      </div>

      <div class="feature-card">
        <h3 class="feature-title">Fully Customizable</h3>
        <p class="feature-desc">
          Every component uses Tailwind classes. Change colors, spacing, and
          typography to match your brand perfectly.
        </p>
        <p class="flex my-5 py-2 px-5 bg-black-onyx text-white-ghost rounded gap-3"><span class="line-through decoration-2 decoration-blue-bell">text-sm text-black-onyx</span>text-lg text-primary</p>
      </div>

      <div class="feature-card">
        <h3 class="feature-title">Beginner Friendly</h3>
        <p class="feature-desc">
          Simple component names. Clean, readable code. Extensive documentation
          with live examples. No confusing abstractions.
        </p>
        <div class="flex gap-3 my-5">
          <button
            class="py-1 px-3 rounded-2xl tracking-tight text-sm bg-black-onyx text-white-ghost"
            >Button</button
          >
          <button
            class="py-1 px-3 rounded-2xl tracking-tight text-sm bg-black-onyx text-white-ghost"
            >Tabs</button
          >
          <button
            class="py-1 px-3 rounded-2xl tracking-tight text-sm bg-black-onyx text-white-ghost"
            >Modal</button
          >
          <button
            class="py-1 px-3 rounded-2xl tracking-tight text-sm bg-black-onyx text-white-ghost"
            >Sidebar</button
          >
        </div>
      </div>
    </div>
  </section>

  <section id="cta" class="bg-black-onyx rounded-xl px-5 text-center">
    <h2 class="text-white-ghost! font-medium text-3xl lg:text-4xl">
      Start Building Right Now
    </h2>
    <Button href="/docs" variant="outline" class="lg:w-fit mx-auto">Get Started</Button>
  </section>
</Layout>
